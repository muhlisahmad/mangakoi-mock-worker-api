# Server
PORT=3000
NODE_ENV=development

# Authentication (generate a random key with: openssl rand -hex 32)
MOCK_API_KEY=dev-mock-api-key-change-in-production

# Simulated pipeline behavior
SIMULATED_DELAY_MIN_MS=1000
SIMULATED_DELAY_MAX_MS=5000
MOCK_FAILURE_RATE=0

# Webhook delivery timeout (ms)
WEBHOOK_TIMEOUT_MS=10000

# CORS
CORS_ORIGIN=*

# Rate limiting (requests per window)
RATE_LIMIT_RUN=1000
RATE_LIMIT_RUNSYNC=2000
RATE_LIMIT_STATUS=2000
RATE_LIMIT_CANCEL=100
RATE_LIMIT_PURGE_QUEUE=2
RATE_LIMIT_HEALTH=2000
